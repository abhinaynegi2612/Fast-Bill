# Bill Analyzer Environment Variables

# Application Settings
DEBUG=false
VERSION=1.0.0

# File Upload Settings
MAX_FILE_SIZE=52428800

# OCR Settings
TESSERACT_CMD=tesseract
OCR_DPI=300
OCR_LANG=eng

# LLM Integration (Optional)
# Set LLM_PROVIDER to 'openai', 'gemini', or 'none'
LLM_PROVIDER=none
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Forgery Detection
FONT_MISMATCH_THRESHOLD=0.8
OCR_MISMATCH_THRESHOLD=0.85
